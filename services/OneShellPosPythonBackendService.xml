<service>
  <id>OneShellPosPythonBackend</id>
  <name>OneShell POS Python Backend</name>
  <description>OneShell POS - Python Backend (OCR, AI Assistant)</description>
  <executable>%BASE%\..\python\python.exe</executable>
  <arguments>"%BASE%\..\apps\PosPythonBackend\main.py"</arguments>
  <workingdirectory>%BASE%\..\apps\PosPythonBackend</workingdirectory>
  <env name="POS_CLIENT_BACKEND_URL" value="http://127.0.0.1:8090"/>
  <env name="OLLAMA_BASE_URL" value="https://ollama.com"/>
  <env name="OLLAMA_MODEL" value="qwen2.5:1.5b"/>
  <env name="OLLAMA_TIMEOUT" value="60"/>
  <env name="PYTHONPATH" value="%BASE%\..\apps\PosPythonBackend"/>
  <logpath>%BASE%\..\logs\PosPythonBackend</logpath>
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <pattern>yyyy-MM-dd</pattern>
    <autoRollAtTime>00:00:00</autoRollAtTime>
  </log>
  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
  <depend>OneShellPosBackend</depend>
  <onfailure action="restart" delay="5 sec"/>
  <onfailure action="restart" delay="15 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <resetfailure>1 hour</resetfailure>
</service>
