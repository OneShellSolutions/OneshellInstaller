<service>
  <id>OneShellPosNodeBackend</id>
  <name>OneShell POS Node Backend</name>
  <description>OneShell POS - Node.js Backend</description>
  <executable>%BASE%\..\node\node.exe</executable>
  <arguments>"%BASE%\..\apps\posNodeBackend\dist\index.js"</arguments>
  <workingdirectory>%BASE%\..\apps\posNodeBackend</workingdirectory>
  <env name="NODE_ENV" value="production"/>
  <env name="PORT" value="3001"/>
  <env name="MONGODB_URI" value="mongodb://127.0.0.1:27017/pos"/>
  <env name="NATS_URL" value="nats://127.0.0.1:4222"/>
  <env name="POS_BACKEND_URL" value="http://127.0.0.1:8090"/>
  <logpath>%BASE%\..\logs\posNodeBackend</logpath>
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <pattern>yyyy-MM-dd</pattern>
    <autoRollAtTime>00:00:00</autoRollAtTime>
    <keepFiles>5</keepFiles>
  </log>
  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
  <depend>OneShellMongoDB</depend>
  <depend>OneShellPosBackend</depend>
  <onfailure action="restart" delay="5 sec"/>
  <onfailure action="restart" delay="15 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="60 sec"/>
  <onfailure action="restart" delay="120 sec"/>
  <resetfailure>1 hour</resetfailure>
</service>
